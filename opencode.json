{
    "$schema": "https://opencode.ai/v1/agent",
    "agent": {
        "profile": {
            "model_tier": "medium",
            "identity_file": "./AGENTS.md"
        },
        "inference": {
            "temperature": 0.5
        }
    },
    "instructions": [
        "./AGENTS.md",
        "./docs/**/*.md"
    ],
    "mcp": {
        "local-filesystem": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "."
            ],
            "enabled": true
        }
    }
}