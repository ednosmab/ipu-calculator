{
  "name": "calculadora-ipu",
  "main": "expo-router/entry",
  "version": "1.2.19",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest",
    "test:lint": "jest --testPathPatterns=\"design-system\"",
    "test:core": "jest --testPathPatterns=\"core\"",
    "test:features": "jest --testPathPatterns=\"features\"",
    "test:integration": "jest --testPathPatterns=\"(Screen|useCalculatorLogic)\"",
    "build": "npx expo export --platform web && node scripts/inject-sw-version.js",
    "build:preview": "npm run build && npx --yes serve dist",
    "test:e2e": "npx playwright test"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.9.19",
    "@react-navigation/native": "^7.2.5",
    "@supabase/supabase-js": "^2.104.1",
    "expo": "~54.0.34",
    "expo-background-fetch": "~14.0.9",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-task-manager": "~14.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.2.7",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "sentry-expo": "~7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.17",
    "dotenv": "^17.4.2",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "expo-secure-store": "^55.0.13",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.0",
    "react-test-renderer": "^19.1.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
